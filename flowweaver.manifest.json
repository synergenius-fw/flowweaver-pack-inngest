{
  "manifestVersion": 2,
  "name": "@synergenius/flow-weaver-pack-inngest",
  "version": "0.2.3",
  "nodeTypes": [],
  "workflows": [],
  "patterns": [],
  "exportTargets": [
    {
      "name": "inngest",
      "description": "Inngest durable event-driven functions",
      "file": "dist/target.js"
    }
  ],
  "compileTargets": [
    {
      "name": "inngest",
      "file": "dist/register.js",
      "description": "Inngest compile target with per-node step.run() durability"
    }
  ],
  "devModeProviders": [
    {
      "name": "inngest",
      "file": "dist/register.js",
      "description": "Inngest local dev server with hot reload"
    }
  ],
  "templates": [
    {
      "type": "workflow",
      "ids": [
        "ai-agent-durable",
        "ai-pipeline-durable"
      ],
      "file": "dist/register.js"
    }
  ]
}
