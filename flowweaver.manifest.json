{
  "manifestVersion": 2,
  "name": "@synergenius/flowweaver-pack-inngest",
  "version": "0.2.0",
  "nodeTypes": [],
  "workflows": [],
  "patterns": [],
  "exportTargets": [{
    "name": "inngest",
